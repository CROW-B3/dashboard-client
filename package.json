{
  "name": "dashboard-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3002 | pino-pretty",
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier src/ --write",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "deploy:prod": "opennextjs-cloudflare build && wrangler deploy --env production",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "cf-typegen:prod": "wrangler types --env production --env-interface CloudflareEnvProd ./cloudflare-env.production.d.ts",
    "cf:migrate:dev": "wrangler d1 migrations apply DB_MAIN --env dev --remote",
    "cf:migrate": "wrangler d1 migrations apply DB_MAIN --remote",
    "cf:migrate:prod": "wrangler d1 migrations apply DB_MAIN --env production --remote",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed.ts",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "setup:ui-kit": "yalc add @b3-crow/ui-kit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.964.0",
    "@b3-crow/ui-kit": "^0.0.38",
    "@opennextjs/cloudflare": "^1.14.8",
    "@tanstack/react-query": "^5.90.21",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "framer-motion": "^12.34.2",
    "katex": "^0.16.37",
    "lenis": "^1.3.16",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.12.3",
    "next": "15.5.6",
    "pino": "^9.5.0",
    "prettier": "^3.7.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint-react/eslint-plugin": "^2.3.5",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wrangler": "^4.47.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
